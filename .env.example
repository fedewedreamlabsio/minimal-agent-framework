MAF_DEFAULT_PROVIDER="openai" # required:core (openai|cerebras|mock)
MAF_DEFAULT_MODEL="gpt-4.1-mini" # required:core (zai-glm-4.7 recommended for cerebras)
OPENAI_API_KEY="" # required:core (if provider=openai)
CEREBRAS_API_KEY="" # required:core (if provider=cerebras)
ANTHROPIC_API_KEY="" # optional:core (if provider=anthropic)

MAF_MAX_STEPS="12" # required:core
MAF_MAX_RUN_SECONDS="90" # required:core
MAF_TRACE_DIR=".maf/runs" # required:core
MAF_HTTP_ALLOWLIST="https://api.github.com,https://httpbin.org" # required:core

E2E_BASE_URL="http://localhost:3000" # required:e2e
E2E_API_BASE_URL="http://localhost:3000" # required:e2e
E2E_BYPASS_TOKEN="" # optional:e2e

DEPLOY_TARGET="" # optional:deploy
DEPLOY_ENV="production" # optional:deploy
